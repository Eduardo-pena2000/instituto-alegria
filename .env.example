# ── Railway (monolito: frontend + backend + DB) ─────────
# Railway inyecta DATABASE_URL automáticamente al vincular PostgreSQL

# ── Stripe ──────────────────────────────────────────────
VITE_STRIPE_PK=pk_test_TU_CLAVE_PUBLICA_DE_STRIPE
STRIPE_SECRET_KEY=sk_test_TU_CLAVE_SECRETA_DE_STRIPE
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Auth ────────────────────────────────────────────────
JWT_SECRET=genera-con-openssl-rand-base64-48

# ── Opcional ────────────────────────────────────────────
# PORT=3001                  (Railway lo asigna automáticamente)
# NODE_ENV=production        (Railway lo setea automáticamente)
# VITE_API_URL=              (vacío en monolito, solo para dev separado)
# CORS_ORIGINS=              (no necesario en monolito)

# ── Twilio WhatsApp (recordatorios automáticos) ─────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=tu_auth_token
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
