generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Student {
  id               String    @id @default(uuid())
  matricula        String    @unique
  nombre           String
  apellido         String
  nivel            String
  grado            String
  grupo            String
  fechaNacimiento  String
  curp             String    @unique
  nombrePadre      String?
  nombreMadre      String?
  telefono         String
  email            String
  direccion        String
  fechaInscripcion String
  ultimoPago       String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  payments         Payment[]
  storeOrders      StoreOrder[]
  notifications    WhatsAppNotification[]
}

model Payment {
  id              String   @id @default(uuid())
  studentId       String
  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentName     String
  nivel           String
  amount          Int
  date            String
  folio           String   @unique
  stripePaymentId String?
  createdAt       DateTime @default(now())
}

model WhatsAppNotification {
  id        String   @id @default(uuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  type      String   // "por_vencer" | "vencida"
  phone     String
  messageSid String?
  status    String   // "sent" | "failed"
  error     String?
  createdAt DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  createdAt DateTime @default(now())
}

model StoreOrder {
  id              String   @id @default(uuid())
  studentId       String
  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentName     String
  items           Json     // Array of items bought: [{name, price, qty, selectedSize}]
  totalCents      Int
  status          String   @default("pending") // "pending" | "delivered" | "cancelled"
  stripePaymentId String?  @unique
  date            String
  createdAt       DateTime @default(now())
}
